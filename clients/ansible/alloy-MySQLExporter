---
- name: Deploy Grafana Alloy
  hosts: all
  become: true

  vars:
    alloy_user: "root"
    alloy_group: "root"
    prometheus_remote_url: "http://10.0.4.8/prometheus/api/v1/write"
    cadvisor_version: "v0.55.1"

  tasks:
    - name: Installer les dépendances (gpg)
      apt:
        name: gpg
        state: present
        update_cache: true

    - name: Créer le répertoire keyrings
      file:
        path: /etc/apt/keyrings
        state: directory
        mode: "0755"

    - name: Télécharger la clé GPG Grafana
      get_url:
        url: https://apt.grafana.com/gpg-full.key
        dest: /etc/apt/keyrings/grafana.asc
        mode: "0644"

    - name: Ajouter le dépôt Grafana (deb822)
      deb822_repository:
        name: grafana
        types: deb
        uris: https://apt.grafana.com
        suites: stable
        components: main
        signed_by: /etc/apt/keyrings/grafana.asc
        state: present

    - name: Installer Alloy
      apt:
        name: alloy
        state: present
        update_cache: true

    - name: Configurer l'override Systemd pour Alloy (exécution en root)
      block:
        - name: Créer le répertoire override
          file:
            path: /etc/systemd/system/alloy.service.d
            state: directory
            mode: "0755"

        - name: Appliquer l'override User/Group
          copy:
            dest: /etc/systemd/system/alloy.service.d/override.conf
            mode: "0644"
            content: |
              [Service]
              User={{ alloy_user }}
              Group={{ alloy_group }}
          notify: Restart Alloy

    - name: Lancer le conteneur cAdvisor
      community.docker.docker_container:
        name: cadvisor
        image: "gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}"
        state: started
        restart_policy: unless-stopped
        privileged: true
        published_ports:
          - "8080:8080"
        volumes:
          - "/:/rootfs:ro"
          - "/var/run:/var/run:ro"
          - "/sys:/sys:ro"
          - "/var/lib/docker/:/var/lib/docker:ro"
          - "/dev/disk/:/dev/disk:ro"
        devices:
          - "/dev/kmsg:/dev/kmsg"

    - name: Déployer la configuration Alloy
      copy:
        dest: /etc/alloy/config.alloy
        mode: "0644"
        content: |
          // --- COLLECTORS ---
          prometheus.exporter.unix "local_host" {
            enable_collectors = ["systemd"]
          }

          prometheus.exporter.mysql "mariadb" {
            data_source_name = "readonly:Password!@(localhost:3306)/"
          }

          // --- SCRAPING ---
          prometheus.scrape "metamonitoring" {
            targets    = prometheus.exporter.unix.local_host.targets
            forward_to = [prometheus.relabel.node_labels.receiver]
            scrape_interval = "15s"
          }

          prometheus.scrape "mysql" {
            targets    = prometheus.exporter.mysql.mariadb.targets
            forward_to = [prometheus.relabel.mysql_labels.receiver]
            scrape_interval = "15s"
          }

          // --- RELABELING ---
          prometheus.relabel "node_labels" {
            forward_to = [prometheus.remote_write.local_prometheus.receiver]
            rule {
              target_label = "job"
              replacement  = "node_exporter"
            }
            rule {
              target_label = "instance"
              replacement  = sys.env("HOSTNAME")
            }
          }

          prometheus.relabel "mysql_labels" {
            forward_to = [prometheus.remote_write.local_prometheus.receiver]
            rule {
              target_label = "job"
              replacement  = "mysql_exporter"
            }
            rule {
              target_label = "instance"
              replacement  = sys.env("HOSTNAME")
            }
          }

          // --- PUSH ---
          prometheus.remote_write "local_prometheus" {
            endpoint {
              url = "{{ prometheus_remote_url }}"
            }
          }
      notify: Restart Alloy

    - name: Activer et démarrer Alloy
      systemd:
        name: alloy
        enabled: true
        state: started
        daemon_reload: true

  handlers:
    - name: Restart Alloy
      systemd:
        name: alloy
        state: restarted
